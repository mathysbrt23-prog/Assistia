{
  "manifest_version": 3,
  "name": "Assistia Reply",
  "description": "Génère ou reformule des réponses professionnelles dans Gmail et WhatsApp Web.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3000/*", "https://*.vercel.app/*"],
  "action": {
    "default_title": "Assistia Reply",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*", "https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
