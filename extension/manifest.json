{
  "manifest_version": 3,
  "name": "Assistia Reply",
  "description": "Génère ou reformule des brouillons professionnels directement dans Gmail.",
  "version": "0.3.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.vercel.app/*",
    "https://assistia.ai/*",
    "https://*.assistia.ai/*"
  ],
  "action": {
    "default_title": "Assistia Reply",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://*.vercel.app/*",
      "https://assistia.ai/*",
      "https://*.assistia.ai/*"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
